name: gram
title: Gram
base: core24
version: "$RELEASE_VERSION"
summary: What cannot be mended must be transcended.
description: |
  Gram is a modern, fully open-source code editor which helps you
  write code without subjecting you to telemetry, AI, proprietary
  server components, license agreements or automatic installation
  of binaries.
grade: stable
confinement: classic
compression: lzo
website: https://codeberg.org/GramEditor/gram
source-code: https://codeberg.org/GramEditor/gram
issues: https://codeberg.org/GramEditor/gram/issues
contact: https://codeberg.org/GramEditor/gram

parts:
  gram:
    plugin: dump
    source: "https://codeberg.org/GramEditor/gram/releases/download/v$RELEASE_VERSION/gram-linux-x86_64.tar.gz"

    organize:
      # These renames seem to not be necessary, but it's tidier.
      bin: usr/bin
      libexec: usr/libexec

    stage-packages:
      - libasound2t64
      # snapcraft has a lint that this is unused, but without it Gram exits with
      # "Missing Vulkan entry points: LibraryLoadFailure" in blade_graphics.
      - libvulkan1
      # snapcraft has a lint that this is unused, but without it Gram exits with
      # "NoWaylandLib" when run with Wayland.
      - libwayland-client0
      - libxcb1
      - libxkbcommon-x11-0
      - libxkbcommon0

    build-attributes:
      - enable-patchelf

    prime:
      # Omit unneeded files from the tarball
      - -lib
      - -licenses.md
      - -share

      # Omit unneeded files from stage-packages
      - -etc
      - -usr/share/doc
      - -usr/share/lintian
      - -usr/share/man

apps:
  gram:
    command: usr/bin/gram
    common-id: se.ziran.Gram
    environment:
      GRAM_BUNDLE_TYPE: snap
